ole from JWT token\nexport const getRoleFromToken = (): AppRole | null => {\n    const accessToken = getAccessToken()\n    if (!accessToken) return null\n  \n    try {\n      const decoded = JSON.parse(atob(accessToken.split('.')[1])) as unknown as {\n        role: string\n      }\n      if (decoded?.role && VALID_ROLES.includes(decoded.role as AppRole)) {\n        return decoded.role as AppRole\n      }\n    } catch (error) {\n      console.error('Failed to decode token:', error)\n    }\n    return null\n  }","usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/utils/obj-utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/utils/parse-error.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/utils/prepare-permissions.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/utils/query-params.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/utils/role-check.util.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/vite-env.d.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fix