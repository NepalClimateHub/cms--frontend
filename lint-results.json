IsUploading(false)\n    toast({\n      variant: 'destructive',\n      title: 'Upload failed. Please try again.',\n    })\n  }\n\n  const handleUploadSuccess = (uploaded: any) => {\n    setIsUploading(false)\n    const url = uploaded?.url\n    if (url) {\n      editor.commands.setImages([{ src: url, caption: caption || undefined }])\n      toast({\n        variant: 'default',\n        title: 'Image added to content',\n      })\n      close()\n    } else {\n      handleUploadError()\n    }\n  }\n\n  return (\n    <form onSubmit={handleSubmit} className='space-y-6'>\n      <div className='space-y-1'>\n        <Label htmlFor='image-link'>Attach an image link</Label>\n        <div className='flex'>\n          <Input\n            id='image-link'\n            type='url'\n            required\n            placeholder='https://example.com'\n            value={link}\n            className='grow'\n            onChange={(e: React.ChangeEvent<HTMLInputElement>) =>\n              setLink(e.target.value)\n            }\n          />\n          <Button type='submit' className='ml-2'>\n            Submit\n          </Button>\n        </div>\n      </div>\n\n      <div className='space-y-1'>\n        <Label htmlFor='image-caption'>Image Caption (optional)</Label>\n        <Input\n          id='image-caption'\n          type='text'\n          placeholder='Enter a caption for this image...'\n          value={caption}\n          onChange={(e: React.ChangeEvent<HTMLInputElement>) =>\n            setCaption(e.target.value)\n          }\n        />\n      </div>\n\n      <div className='space-y-3'>\n        <Label>Or upload from your computer</Label>\n        <MiniLoader isLoading={isLoading}>\n          <IKContext\n            publicKey={publicKey}\n            urlEndpoint={endpoint}\n            authenticator={() => new Promise((resolve) => resolve(ikAuthParams))}\n          >\n            <IKUpload\n              disabled={isUploading}\n              isUploading={isUploading}\n              label='Upload image'\n              description='Image size should not exceed 5MB!'\n              folder={folder}\n              isPrivateFile={false}\n              useUniqueFileName={true}\n              onError={handleUploadError}\n              onSuccess={handleUploadSuccess}\n              onUploadStart={handleUploadStart}\n              validateFile={(file: File) => {\n                if (!ALLOWED_IMAGE_TYPES.includes(file.type)) {\n                  toast({\n                    variant: 'destructive',\n                    title: 'Only jpg, png, and webp formats are supported.',\n                  })\n                  return false\n                }\n                const sizeInMb = Math.floor(file.size / 1000000)\n                if (sizeInMb > 5) {\n                  toast({\n                    variant: 'destructive',\n                    title: 'Image size cannot be greater than 5MB.',\n                  })\n                  return false\n                }\n                return true\n              }}\n              checks={`\"file.size\" < \"5mb\"`}\n            />\n          </IKContext>\n        </MiniLoader>\n      </div>\n    </form>\n  )\n}\n\nexport default ImageEditBlock\n","usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/ui/minimal-tiptap/components/image/image-edit-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/ui/minimal-tiptap/components/link/link-edit-block.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/ui/minimal-tiptap/components/link/link-edit-popover.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErr