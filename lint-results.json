)\n\n  return (\n    <div className='flex h-10 overflow-hidden rounded bg-background p-2 shadow-lg'>\n      <div className='inline-flex items-center gap-1'>\n        <ToolbarButton\n          tooltip='Edit link'\n          onClick={onEdit}\n          className='w-auto px-2'\n        >\n          Edit link\n        </ToolbarButton>\n        <Separator orientation='vertical' />\n        <ToolbarButton\n          tooltip='Open link in a new tab'\n          onClick={handleOpenLink}\n        >\n          <ExternalLinkIcon className='size-4' />\n        </ToolbarButton>\n        <Separator orientation='vertical' />\n        <ToolbarButton tooltip='Clear link' onClick={onClear}>\n          <LinkBreak2Icon className='size-4' />\n        </ToolbarButton>\n        <Separator orientation='vertical' />\n        <ToolbarButton\n          tooltip={copyTitle}\n          onClick={handleCopy}\n          tooltipOptions={{\n            onPointerDownOutside: (e: any) => {\n              if (e.target === e.currentTarget) e.preventDefault()\n            },\n          }}\n        >\n          <CopyIcon className='size-4' />\n        </ToolbarButton>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/ui/minimal-tiptap/components/measured-container.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/ui/minimal-tiptap/components/section/five.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/sdsys/Files/nepalclimatehub/cms--frontend/src/ui/minimal-tiptap/components/section/four.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWar